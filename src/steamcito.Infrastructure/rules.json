{
  "storeRules": [
    {
      "contains": "steam_api",
      "store": "Steam"
    },
    {
      "contains": "OnlineFix",
      "store": "Steam"
    },
    {
      "contains": "EOSSDK",
      "store": "EpicGames"
    },
    {
      "contains": "uplay_r1_loader",
      "store": "Uplay"
    },
    {
      "contains": "Origin",
      "store": "Origin"
    }
  ],
  "roleRules": [
    {
      "role": "Original",
      "requiresSigned": true
    },
    {
      "role": "OnlineFix",
      "requiresSigned": false,
      "category": "Wrapper",
      "matchAny": [
        {
          "field": "FileDescription",
          "contains": "Online-Fix Steamclient"
        }
      ],
      "anyFile": [
        "OnlineFix.ini"
      ],
      "requires": ["RealSteamApi"]
    },
    {
      "role": "Rune",
      "requiresSigned": false,
      "category": "Emulator",
      "matchAny": [
        {
          "field": "LegalCopyright",
          "contains": "NisCkxU544c"
        }
      ],
      "anyFile": [
        "steam_emu.ini"
      ]
    },
    {
      "role": "SmokeAPI",
      "requiresSigned": false,
      "category": "Wrapper",
      "matchAny": [
        {
          "field": "ProductName",
          "contains": "SmokeAPI"
        },
        {
          "field": "LegalCopyright",
          "contains": "Fuck the copyright"
        },
        {
          "field": "FileDescription",
          "contains": "Steamworks DLC unlocker"
        }
      ],
      "anyFile": [
        "SmokeAPI.*",
        "SmokeAPI.config.json"
      ],
      "requires": ["RealSteamApi"]
    },
    {
      "role": "CreamAPI",
      "requiresSigned": false,
      "category": "Wrapper",
      "anyFile": [
        "cream_api.ini"
      ],
      "requires": ["RealSteamApi"]
    },
    {
      "role": "GoldbergEmu",
      "requiresSigned": false,
      "category": "Emulator",
      "matchAny": [
        {
          "field": "ProductName",
          "contains": "GSE Client API"
        },
        {
          "field": "FileDescription",
          "contains": "GSE Client API"
        }
      ]
    },
    {
      "role": "ScreamAPI",
      "requiresSigned": false,
      "category": "Wrapper",
      "matchAny": [
        {
          "field": "ProductName",
          "contains": "ScreamAPI"
        }
      ],
      "anyFile": [
        "ScreamAPI.*"
      ],
      "requires": ["RealSteamApi"]
    },
    {
      "role": "GenericFix",
      "requiresSigned": false
    }
  ]
}