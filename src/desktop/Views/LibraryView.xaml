<UserControl x:Class="steamcito.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:steamcito.ViewModels">

    <Grid Background="#1B2838">

        <!-- COLUMNAS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <!-- SIDEBAR -->
            <ColumnDefinition Width="*"/>
            <!-- MAIN -->
        </Grid.ColumnDefinitions>

        <!-- ===================== -->
        <!-- SIDEBAR -->
        <!-- ===================== -->
        <Grid Background="#171A21">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Search -->
                <RowDefinition Height="*"/>
                <!-- Lista -->
            </Grid.RowDefinitions>

            <!-- BUSCADOR -->
            <TextBox Margin="10"
                     Height="30"
                     Background="#2A475E"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="5"
                     Text="Search..."/>

            <!-- LISTA DE JUEGOS -->
            <ScrollViewer Grid.Row="1">
                <ListBox ItemsSource="{Binding Games}" 
                         SelectedItem="{Binding SelectedGame}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Details.Title}" 
                                       Margin="5"
                                       Foreground="White"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- ===================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================== -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="250"/>
                <!-- HEADER -->
                <RowDefinition Height="Auto"/>
                <!-- BOTONES -->
                <RowDefinition Height="*"/>
                <!-- INFO -->
            </Grid.RowDefinitions>

            <!-- HEADER (imagen grande del juego) -->
            <Grid>
                <Image Source="/Assets/header.jpg"
                       Stretch="UniformToFill"/>

                <!-- Overlay oscuro -->
                <Rectangle Fill="#80000000"/>

                <!-- Título -->
                <TextBlock Text="{Binding SelectedGame.Details.Title, StringFormat='Game: {0}'}"
                           Foreground="White"
                           FontSize="40"
                           Margin="20"
                           VerticalAlignment="Bottom"/>
            </Grid>

            <!-- BOTONES -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="20">

                <Button x:Name="PlayButton" 
                        Content="Play"
                        Width="150"
                        Height="40"
                        Background="#1DB954"
                        Foreground="White"
                        Padding="15,10"
                        FontSize="16"
                        BorderThickness="0"
                        Command="{Binding RunGameCommand}"/>

                <Button Content="⚙"
                        Width="40"
                        Height="40"
                        Margin="10,0"
                        Background="#2A475E"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>

            <!-- INFO -->
            <Grid Grid.Row="2" Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- PANEL IZQUIERDO -->
                <StackPanel>
                    <TextBlock x:Name="aboutText" Text="About the game"
                               Foreground="White"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                    <Border Background="#2A475E"
                            Height="113" Width="686" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform AngleX="0"/>
                                <RotateTransform/>
                                <TranslateTransform X="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                    </Border>
                </StackPanel>

                <!-- PANEL DERECHO -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0"/>

            </Grid>

        </Grid>
        <Grid Grid.Column="1" HorizontalAlignment="Center" Width="730" Height="611" VerticalAlignment="Top"/>

    </Grid>
</UserControl>