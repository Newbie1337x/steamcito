<UserControl x:Class="steamcito.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:steamcito.ViewModels">

    <Grid Background="#1B2838">

        <!-- COLUMNAS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <!-- SIDEBAR -->
            <ColumnDefinition Width="*"/>
            <!-- MAIN -->
        </Grid.ColumnDefinitions>

        <!-- ===================== -->
        <!-- SIDEBAR -->
        <!-- ===================== -->
        <Grid Background="#171A21">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Search -->
                <RowDefinition Height="*"/>
                <!-- Lista -->
            </Grid.RowDefinitions>

            <!-- BUSCADOR -->
            <TextBox Margin="10"
                     Height="30"
                     Background="#2A475E"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="5"
                     Text="Search..."/>

            <!-- LISTA DE JUEGOS -->
            <ScrollViewer Grid.Row="1">
                <ListBox ItemsSource="{Binding Games}" 
                         SelectedItem="{Binding SelectedGame}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="IconBorder" 
                                                Padding="10,8" 
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="2,0,0,0">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="IconBorder" Property="Background" Value="#3a424b" />
                                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#66C0F4" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="IconBorder" Property="Background" Value="#2b3138" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Details.Title}" 
                                       FontSize="14"
                                       Foreground="#8F98A0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- ===================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================== -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="300"/> <!-- HEADER -->
                <RowDefinition Height="Auto"/> <!-- BOTONES -->
                <RowDefinition Height="*"/> <!-- INFO -->
            </Grid.RowDefinitions>

            <!-- HEADER (imagen grande del juego) -->
            <Grid Grid.Row="0">
                <Image Source="/Assets/header.jpg"
                       Stretch="UniformToFill"/>

                <!-- Overlay oscuro gradual -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0.5"/>
                            <GradientStop Color="#CC1B2838" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Título -->
                <TextBlock Text="{Binding SelectedGame.Details.Title}"
                           Foreground="White"
                           FontSize="48"
                           FontWeight="Bold"
                           Margin="30,0,0,30"
                           VerticalAlignment="Bottom">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <!-- BOTONES -->
            <Border Grid.Row="1" Background="#1B2838" BorderBrush="#2A475E" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="30,15">

                    <Button x:Name="PlayButton" 
                            Content="Play"
                            Width="160"
                            Height="45"
                            Background="#5c7e10"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding RunGameCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="⚙"
                            Width="45"
                            Height="45"
                            Margin="15,0"
                            Background="#3d4450"
                            Foreground="White"
                            FontSize="20"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- INFO -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- PANEL IZQUIERDO -->
                    <StackPanel>
                        <TextBlock Text="About the game"
                                   Foreground="#66C0F4"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <Border Background="#171A21"
                                CornerRadius="5"
                                Padding="20"
                                MinHeight="200">
                            <TextBlock Text="{Binding SelectedGame.Details.Description, FallbackValue='No description available for this game.'}"
                                       Foreground="White"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- PANEL DERECHO -->
                    <StackPanel Grid.Column="1" Margin="30,0,0,0">
                        <TextBlock Text="Details"
                                   Foreground="#66C0F4"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Margin="0,5">
                            <TextBlock Text="PLAYED TIME" Foreground="#8F98A0" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedGame.Details.PlayedTime, StringFormat=\{0:hh\\:mm\} hs}" Foreground="White" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Margin="0,10">
                            <TextBlock Text="LAST SESSION" Foreground="#8F98A0" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedGame.Details.LastTime, StringFormat=\{0:dd/MM/yyyy\}, FallbackValue='Never'}" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>