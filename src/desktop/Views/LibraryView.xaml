<UserControl x:Class="steamcito.Views.LibraryView"
             x:Name="RootView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:steamcito.ViewModels"
             
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"

             d:DataContext="{d:DesignInstance Type=local:LibraryViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ContextMenuStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Background="#1B2838">

        <!-- COLUMNAS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <!-- SIDEBAR -->
            <ColumnDefinition Width="*"/>
            <!-- MAIN -->
        </Grid.ColumnDefinitions>

        <!-- ===================== -->
        <!-- SIDEBAR -->
        <!-- ===================== -->
        <Grid Background="#171A21">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Search -->
                <RowDefinition Height="*"/>
                <!-- Lista -->
            </Grid.RowDefinitions>

            <!-- BUSCADOR -->
            <TextBox Margin="10"
                     Height="30"
                     Background="#2A475E"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="5"
                     Text="Search..."/>

            <!-- LISTA DE JUEGOS -->
                <ListBox Grid.Row="1" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemsSource="{Binding Games}" 
                         SelectedItem="{Binding SelectedGame}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, ElementName=RootView}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">

                                        <!-- PLAY -->
                                        <MenuItem FontWeight="SemiBold"
                                                  Foreground="White"
                                                  Command="{Binding PlayGameCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Header" Value="▶ Play" />
                                                    <Setter Property="Background" Value="#3d922e"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                            <Setter Property="Header" Value="◼ Stop" />
                                                            <Setter Property="Background" Value="#A03131"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter Property="Background" Value="#55c03d"/>
                                                        </Trigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsHighlighted, RelativeSource={RelativeSource Self}}" Value="True" />
                                                                <Condition Binding="{Binding PlacementTarget.DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#C04040"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>

                                       
                                        <MenuItem Command="{Binding ToggleFavoriteCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                    <Setter Property="Header" Value="Add to favorites" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Details.Favorite, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                            <Setter Property="Header" Value="Remove from favorites" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>
                                            
                                    
                                        
                                        <!-- Manage -->
                                        <MenuItem Header="Manage">

                                            <MenuItem Header="Add desktop shortcut"
                                                      Command="{Binding CreateShortcutCommand}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />

                                            <MenuItem Header="Browse local files"
                                                      Command="{Binding OpenFolderCommand}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.GamePaths.FolderPath, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />

                                            <MenuItem Header="Remove"
                                                      Command="{Binding RemoveGameCommand}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />

                                       
                                        </MenuItem>
                                        <MenuItem Header="Properties..."
                                                  Command="{Binding OpenPropertiesCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            
                                        </MenuItem>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="IconBorder" 
                                                Padding="10,8" 
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="2,0,0,0">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="IconBorder" Property="Background" Value="#3a424b" />
                                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#66C0F4" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="IconBorder" Property="Background" Value="#2b3138" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Details.Title}" 
                                       FontSize="14"
                                       Foreground="#8F98A0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
        </Grid>

        <!-- ===================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================== -->
        <Grid Grid.Column="1" Background="#1B2838">
            
            <ScrollViewer x:Name="MainScroll"
                          ScrollChanged="MainScroll_ScrollChanged"
                          VerticalScrollBarVisibility="Auto"
                          BorderThickness="0">
                
                <StackPanel>
                    <Grid x:Name="BannerArea" Height="300" Background="#10141B">
                        <Image Source="{Binding SelectedGame.Artworks.Hero}" Stretch="UniformToFill"/>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0.5"/>
                                    <GradientStop Color="#CC1B2838" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="{Binding SelectedGame.Details.Title}"
                                   Foreground="White" FontSize="48" FontWeight="Bold"
                                   Margin="30,0,0,0" VerticalAlignment="Bottom">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="30,80,30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="About the game" Foreground="#66C0F4" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Border Background="#171A21" CornerRadius="5" Padding="20" MinHeight="200">
                                <TextBlock Text="{Binding SelectedGame.Details.Description, FallbackValue='No description available for this game.'}"
                                           Foreground="White" FontSize="14" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="30,0,0,0">
                            <TextBlock Text="Details" Foreground="#66C0F4" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <StackPanel Margin="0,5">
                                <TextBlock Text="PLAYED TIME" Foreground="#8F98A0" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedGame.Details.PlayTime, StringFormat=\{0:hh\\:mm\} hs}" Foreground="White" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Margin="0,10">
                                <TextBlock Text="LAST SESSION" Foreground="#8F98A0" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedGame.Details.LastTime, StringFormat=\{0:dd/MM/yyyy\}, FallbackValue='Never'}" Foreground="White" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Margin="0,10">
                                <TextBlock Text="STORE" Foreground="#8F98A0" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedGame.Details.Store,FallbackValue='Other'}" Foreground="White" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Margin="0,10">
                                <TextBlock Text="HAS ORIGINAL DLL" Foreground="#8F98A0" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedGame.Details.IsSigned}" Foreground="White" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="StickyButtonsPanel" 
                    Background="Transparent" 
                    BorderBrush="#2A475E" 
                    BorderThickness="0,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Height="60"
                    Margin="0,250,0,0">
                
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="20,0"
                            VerticalAlignment="Center">
                    
                    <Button x:Name="PlayButton" 
                            Width="160"
                            Height="45"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding PlayGameCommand}"
                            CommandParameter="{Binding SelectedGame}"
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                        
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"></Setter>
                            </Style>
                            
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="▶ PLAY"/>
                                <Setter Property="Background" Value="#3d922e"/>
                                
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedGame.IsRunning}" Value="True">
                                        <Setter Property="Content" Value="◼ Stop"/>
                                        <Setter Property="Background" Value="#A03131"/>
                                    </DataTrigger>
                                    
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#55c03d"/>
                                    </Trigger>
                                    
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                            <Condition Binding="{Binding SelectedGame.IsRunning}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#C04040"/>
                                    </MultiDataTrigger>
                                    
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#66d04e"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="⚙"
                            Width="45"
                            Height="45"
                            Margin="15,0"
                            Background="#3d4450"
                            Foreground="White"
                            FontSize="20"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding OpenPropertiesCommand}"
                            CommandParameter="{Binding SelectedGame}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="9"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>