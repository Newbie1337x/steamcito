<Window x:Class="steamcito.Views.GamePropertiesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:steamcito.Views"
        mc:Ignorable="d"
        Title="Properties" Height="450" Width="800"
        Style="{StaticResource {x:Type Window}}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        BorderBrush="{StaticResource WindowBorder}"
        BorderThickness="2"
        Padding="1">
    <Grid>
        <Grid Background="#1B2838">

            
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================== -->
            <!-- SIDEBAR -->
            <!-- ===================== -->
            <StackPanel Background="#171A21">
                
                <TextBlock Text="{Binding SelectedGame.Details.Title}"
                   Foreground="#66C0F4"
                   Margin="15"
                   FontSize="20"
                   FontWeight="Bold"
                   Padding = "10,0"
                   TextWrapping="Wrap"/>

                <ListBox SelectedIndex="0"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="White">

                    <ListBoxItem Content="General" />
                    <ListBoxItem Content="Installed Files"/>




                    <ListBoxItem Content="Customization"/>

                </ListBox>
            </StackPanel>
            <ContentControl Grid.Column="1" Content="TODO: Aca deberia ir algo?" HorizontalAlignment="Center" VerticalAlignment="Center" Height="434" Width="580"/>

            <!-- ===================== -->
            <!-- MAIN -->
            <!-- ===================== -->
        </Grid>
    </Grid>
</Window>
