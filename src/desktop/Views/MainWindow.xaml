<Window x:Class="steamcito.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:steamcito.Views"
        Title="MainWindow" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource SteamWindowStyle}" 
        BorderBrush="#FF4A4A4A"
        Padding="10"
        Margin="50"
        BorderThickness="2">
    
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="50"/> 
            <RowDefinition Height="*"/>  
            <RowDefinition Height="45"/> 
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" 
            Background="#FF171D25" 
            CornerRadius="15,15,0,0" 
            MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            
            <Grid Grid.Row="0" Background="#FF171D25" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            
                <TextBlock Text="STEAMCITO" 
                            FontSize="10" 
                            FontWeight="Bold" 
                            Foreground="Gray" 
                            VerticalAlignment="Center" 
                            Margin="15,0,0,0"/>

                <StackPanel Orientation="Horizontal" Grid.Column="1" 
                            WindowChrome.IsHitTestVisibleInChrome="True" 
                            Margin="0,0,10,0"> 
                    <Button Content="—" Width="45" Height="25" Background="Transparent" Foreground="White" BorderThickness="0" Click="Minimize_Click"/>
                    <Button Content="☐" Width="45" Height="25" Background="Transparent" Foreground="White" BorderThickness="0" Click="Maximize_Click"/>
                    <Button Content="X" Width="45" Height="25" Background="Transparent" Foreground="White" BorderThickness="0" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Background="#FF171D25">
            <StackPanel Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="15,0,0,0" 
                        WindowChrome.IsHitTestVisibleInChrome="True"> 
                
                <Button x:Name="LibraryButton" 
                        Content="Library" 
                        Width="100" 
                        Margin="0,0,15,0" 
                        Click="LibraryButton_Click" 
                        Background="Transparent" 
                        FontSize="18" 
                        BorderThickness="0" 
                        Foreground="White"/>

                <Button x:Name="SettingsButton" 
                        Content="Settings" 
                        Width="100" 
                        Click="SettingsButton_Click" 
                        Background="Transparent" 
                        FontSize="18" 
                        BorderThickness="0" 
                        Foreground="White"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <ContentControl x:Name="MainContent" Background="#FF222222"/>
            
            <local:LibraryView x:Name="LibraryViewControl" Visibility="Visible"/>
            <local:SettingsView x:Name="SettingsViewControl" Visibility="Hidden"/>
        </Grid>

        <Grid Grid.Row="3" Background="#FF171D25">
            <Button x:Name="AddProductButton" 
                    Content="+ Add a product" 
                    Margin="15,0,0,0" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center"
                    Click="AddProduct_Click" 
                    Foreground="#FF999999" 
                    Background="Transparent" 
                    BorderThickness="0"
                    WindowChrome.IsHitTestVisibleInChrome="True"/> 
        </Grid>
    </Grid>
</Window>