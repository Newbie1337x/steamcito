<Window x:Class="steamcito.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:steamcito.Views"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <!-- FILAS -->
        <Grid.RowDefinitions>
            
            <!-- HEADER -->
            <RowDefinition Height="40"/>
            <!-- CONTENT -->
            <RowDefinition Height="*"/>
            <!-- FOOTER -->
            <RowDefinition Height="40"/>
            
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="#FF171D25">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="10,0,0,0">
        
                <Button x:Name="LibraryButton"
                        Content="Library"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="LibraryButton_Click"
                        Background="#00DDDDDD"
                        FontSize="18"
                        BorderBrush="#00171D25"
                        Foreground="White"/>

                <Button x:Name="SettingsButton"
                        Content="Settings"
                        Width="120"
                        Click="SettingsButton_Click"
                        Background="#00DDDDDD"
                        FontSize="18"
                        BorderBrush="#00171D25"
                        Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="152"/>
                <!-- SIDEBAR -->
                <ColumnDefinition Width="*"/>
                <!-- MAIN -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->

            <!-- MAIN CONTENT DINÁMICO -->
            <ContentControl x:Name="MainContent" Grid.ColumnSpan="3" Background="#FF222222"/>
            <local:LibraryView x:Name="LibraryViewControl" Grid.ColumnSpan="3" Grid.Column="0" Visibility="Hidden"/>
            <local:SettingsView x:Name="SettingsViewControl" Grid.ColumnSpan="3" Grid.Column="0" Visibility="Hidden"/>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2" Background="#FF171D25">
            <Button x:Name="AddProductButton"
                    Content="Add a product"
                    Margin="10,0,0,10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Click="AddProduct_Click" Foreground="White" Background="#00DDDDDD" BorderBrush="#00707070"/>
        </Grid>

    </Grid>
</Window>