<Window x:Class="steamcito.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <!-- FILAS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <!-- HEADER -->
            <RowDefinition Height="*"/>
            <!-- CONTENT -->
            <RowDefinition Height="40"/>
            <!-- FOOTER -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="#222">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="21*"/>
                <ColumnDefinition Width="29*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0" Grid.ColumnSpan="2">
                <Button x:Name="LibraryButton" Content="Library" Width="100"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <!-- SIDEBAR -->
                <ColumnDefinition Width="*"/>
                <!-- MAIN -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->

            <!-- MAIN CONTENT DINÁMICO -->
            <Frame x:Name="MainFrame"
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden"
                   Margin="10"/>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2" Background="#222">
            <Button x:Name="AddProductButton"
                    Content="Add a product"
                    Margin="10,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Click="AddProduct_Click"/>
        </Grid>

    </Grid>
</Window>